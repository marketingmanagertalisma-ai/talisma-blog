      "required": true
    },
    "desc": {
      "type": "text",
      "required": true
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "detail_page_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "about": {
      "type": "text",
      "required": true
    },
    "Industry": {
      "type": "string",
      "required": true
    },
    "Company_Size": {
      "type": "string",
      "required": true
    },
    "Founded": {
      "type": "integer",
      "required": true
    },
    "Headquarters": {
      "type": "string",
      "required": true
    }
  }
